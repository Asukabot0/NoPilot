{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Build Review Artifact",
  "version": "4.0",
  "type": "object",
  "required": ["phase", "session", "review_complexity", "self_fix_cap", "scenario_walkthroughs", "acceptance_summary", "ai_bias_detection", "self_fix_log", "trend_evaluation", "recommendation"],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["build_review"]
    },
    "session": {
      "type": "string",
      "enum": ["independent"]
    },
    "review_complexity": {
      "type": "string",
      "enum": ["simple", "medium", "complex"]
    },
    "self_fix_cap": {},
    "scenario_walkthroughs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario_id", "critic_result", "evidence", "confidence"],
        "properties": {
          "scenario_id": {
            "type": "string",
            "pattern": "^SCENARIO-\\d{3}$"
          },
          "critic_result": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "evidence": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "ai_bias_flags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "acceptance_summary": {
      "type": "object",
      "required": ["status", "passed_scenarios", "failed_scenarios"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["all_passed", "partial", "failed"]
        },
        "passed_scenarios": { "type": "array", "items": { "type": "string" } },
        "failed_scenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["scenario_id", "expected_behavior", "actual_behavior", "severity", "confidence"],
            "properties": {
              "scenario_id": { "type": "string" },
              "expected_behavior": { "type": "string" },
              "actual_behavior": { "type": "string" },
              "severity": { "type": "string", "enum": ["block"] },
              "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
              "ai_bias_flags": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "ai_bias_detection": {
      "type": "object",
      "required": ["patterns_found"],
      "properties": {
        "patterns_found": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["bias_type", "target_id", "evidence", "confidence"],
            "properties": {
              "bias_type": {
                "type": "string",
                "enum": ["over_engineering", "optimistic_assessment", "missing_negative_paths", "concept_conflation", "self_approval_bias", "anchoring", "symmetric_completion"]
              },
              "target_id": { "type": "string" },
              "evidence": { "type": "string" },
              "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
            }
          }
        }
      }
    },
    "self_fix_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["iteration", "fixes_applied", "reverify_result", "remaining_blocks", "remaining_warns"],
        "properties": {
          "iteration": { "type": "number" },
          "fixes_applied": { "type": "array", "items": { "type": "string" } },
          "reverify_result": { "type": "string", "enum": ["passed", "still_failing"] },
          "remaining_blocks": { "type": "number" },
          "remaining_warns": { "type": "number" }
        }
      }
    },
    "trend_evaluation": {
      "type": "object",
      "required": ["assessed"],
      "properties": {
        "assessed": { "type": "boolean" },
        "trend": { "type": ["string", "null"], "enum": ["converging", "diverging", "oscillating", null] },
        "action": { "type": ["string", "null"], "enum": ["extended", "stop_stronger_model", "stop_human_decision", null] },
        "detail": { "type": ["string", "null"] }
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["pass", "L2", "L3"]
    },
    "detail": { "type": "string" }
  }
}
