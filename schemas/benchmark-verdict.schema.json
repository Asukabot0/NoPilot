{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "needs_review",
        "pending_review"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
