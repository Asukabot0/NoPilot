{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tests Artifact",
  "version": "4.0",
  "type": "object",
  "required": ["phase", "version", "example_cases", "property_cases", "coverage_summary", "coverage_guards"],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["tests"]
    },
    "artifact": {
      "type": "string",
      "enum": ["tests"]
    },
    "version": {
      "type": "string"
    },
    "example_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "suite_type", "module_ref", "requirement_refs", "description", "category", "ears_ref", "derivation", "input", "expected_output"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TEST-\\d{3}$"
          },
          "suite_type": {
            "type": "string",
            "enum": ["unit", "integration", "e2e", "contract", "state_transition"]
          },
          "module_ref": {
            "type": "string",
            "pattern": "^MOD-\\d{3}$"
          },
          "requirement_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["normal", "boundary", "error", "regression"]
          },
          "ears_ref": { "type": "string" },
          "derivation": {
            "type": "string",
            "enum": ["direct_from_ears", "ai_supplemented"]
          },
          "input": {},
          "expected_output": {},
          "setup": { "type": "string" }
        }
      }
    },
    "property_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "module_ref", "invariant_ref", "property", "requirement_refs"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^PROP-\\d{3}$"
          },
          "module_ref": {
            "type": "string",
            "pattern": "^MOD-\\d{3}$"
          },
          "invariant_ref": {
            "type": "string",
            "pattern": "^INV-\\d{3}$"
          },
          "property": { "type": "string" },
          "requirement_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "coverage_summary": {
      "type": "object",
      "required": ["requirements_covered", "requirements_uncovered", "invariants_covered", "invariants_uncovered"],
      "properties": {
        "requirements_covered": { "type": "array", "items": { "type": "string" } },
        "requirements_uncovered": { "type": "array", "items": { "type": "string" } },
        "invariants_covered": { "type": "array", "items": { "type": "string" } },
        "invariants_uncovered": { "type": "array", "items": { "type": "string" } },
        "state_transitions_covered": { "type": "array", "items": { "type": "string" } },
        "illegal_transitions_tested": { "type": "array", "items": { "type": "string" } }
      }
    },
    "coverage_guards": {
      "type": "object",
      "required": ["invariants_uncovered_must_be_empty", "requirements_uncovered_must_be_empty"],
      "properties": {
        "invariants_uncovered_must_be_empty": { "type": "boolean" },
        "requirements_uncovered_must_be_empty": { "type": "boolean" }
      }
    }
  }
}
