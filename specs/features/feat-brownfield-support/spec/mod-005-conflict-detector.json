{
  "id": "MOD-005",
  "name": "conflict-detector",
  "responsibility": "Detects conflicts between feature requirements and existing project profile (design philosophy, constraints, architecture decisions). Presents ADAPT/EVOLVE/DEFER decision protocol. Also handles domain model entity name collision detection.",
  "source_root": "src/profile/",
  "owned_files": [
    "src/profile/conflict-detector.ts"
  ],
  "interfaces": [
    {
      "type": "internal",
      "name": "detectConflicts",
      "input_schema": {
        "type": "object",
        "properties": {
          "featureRequirements": {
            "type": "object",
            "description": "Feature discover artifact (requirements, tech_direction, domain_model)"
          },
          "profile": {
            "type": "object",
            "description": "Relevant profile layers (L0, L1, L2 if available, L3)"
          }
        },
        "required": ["featureRequirements", "profile"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "conflicts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {"type": "string", "description": "CONFLICT-001, CONFLICT-002, ..."},
                "type": {"type": "string", "enum": ["philosophy", "constraint", "architecture", "domain_model"]},
                "profileEntry": {"type": "string", "description": "The specific profile content that conflicts"},
                "profileLayer": {"type": "string", "enum": ["l0", "l1", "l2", "l3"]},
                "featureEntry": {"type": "string", "description": "The specific feature requirement that conflicts"},
                "severity": {"type": "string", "enum": ["high", "medium", "low"]},
                "description": {"type": "string"}
              }
            }
          },
          "hasBlockingConflicts": {"type": "boolean"}
        }
      },
      "errors": [],
      "api_detail": null,
      "requirement_refs": ["REQ-007", "REQ-008", "REQ-014"],
      "acceptance_criteria_refs": ["REQ-007-AC-1", "REQ-007-AC-3", "REQ-008-AC-1", "REQ-008-AC-2", "REQ-014-AC-1", "REQ-014-AC-3"]
    },
    {
      "type": "internal",
      "name": "resolveConflict",
      "input_schema": {
        "type": "object",
        "properties": {
          "conflictId": {"type": "string"},
          "resolution": {"type": "string", "enum": ["ADAPT", "EVOLVE", "DEFER"]}
        },
        "required": ["conflictId", "resolution"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "resolved": {"type": "boolean"},
          "action": {
            "type": "string",
            "description": "ADAPT: requirement modified to fit. EVOLVE: architecture evolution flagged for profile update. DEFER: feature requirement moved to V2."
          },
          "profileUpdateFlag": {"type": "boolean", "description": "True if EVOLVE was chosen — profile should be updated after build"}
        }
      },
      "errors": ["CONFLICT_NOT_FOUND"],
      "api_detail": null,
      "requirement_refs": ["REQ-007"],
      "acceptance_criteria_refs": ["REQ-007-AC-2", "REQ-007-AC-4"]
    }
  ],
  "data_models": [
    {
      "name": "Conflict",
      "fields": [
        {"name": "id", "type": "string", "constraints": "CONFLICT-NNN format"},
        {"name": "type", "type": "'philosophy' | 'constraint' | 'architecture' | 'domain_model'", "constraints": "required"},
        {"name": "profileEntry", "type": "string", "constraints": "verbatim from profile"},
        {"name": "profileLayer", "type": "'l0' | 'l1' | 'l2' | 'l3'", "constraints": "which layer the conflict is in"},
        {"name": "featureEntry", "type": "string", "constraints": "verbatim from feature discover"},
        {"name": "severity", "type": "'high' | 'medium' | 'low'", "constraints": "high = blocking, medium = warning, low = info"},
        {"name": "description", "type": "string", "constraints": "human-readable explanation"},
        {"name": "resolution", "type": "'ADAPT' | 'EVOLVE' | 'DEFER' | null", "constraints": "null until resolved"}
      ],
      "relationships": []
    }
  ],
  "state_machine": null,
  "nfr_constraints": {
    "performance": null,
    "security": null,
    "other": "Conflict detection is LLM-driven semantic comparison. When L2 is absent or disabled, conflict detection operates on L0/L1 structural data only (REQ-014-AC-2). L2 is the primary anchor when available (REQ-014-AC-3)."
  },
  "requirement_refs": ["REQ-007", "REQ-008", "REQ-014"],
  "invariant_refs": ["INV-002", "INV-003"]
}
