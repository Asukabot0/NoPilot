{
  "id": "MOD-004",
  "name": "mode-detector",
  "responsibility": "Two-dimensional detection (profile existence × codebase existence) to determine flow mode. Handles four paths: pure greenfield, first-time onboarding, returning project with mode prompt. Outputs a mode context variable consumed by all downstream stages.",
  "source_root": "src/profile/",
  "owned_files": [
    "src/profile/mode-detector.ts"
  ],
  "interfaces": [
    {
      "type": "internal",
      "name": "detectMode",
      "input_schema": {
        "type": "object",
        "properties": {
          "rootDir": {"type": "string"}
        },
        "required": ["rootDir"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "hasProfile": {"type": "boolean"},
          "hasCode": {"type": "boolean"},
          "detectedPath": {
            "type": "string",
            "enum": ["pure_greenfield", "first_time_onboarding", "returning_project"],
            "description": "pure_greenfield: no code, no profile. first_time_onboarding: code exists, no profile. returning_project: profile exists."
          },
          "codeIndicators": {"type": "array", "items": {"type": "string"}, "description": "What code was detected (git_history, package.json, etc.)"},
          "profileLayers": {
            "type": "object",
            "properties": {
              "l0": {"type": "boolean"},
              "l1": {"type": "boolean"},
              "l2": {"type": "boolean"},
              "l3": {"type": "boolean"}
            }
          }
        }
      },
      "errors": [],
      "api_detail": null,
      "requirement_refs": ["REQ-004"],
      "acceptance_criteria_refs": ["REQ-004-AC-1", "REQ-004-AC-2", "REQ-004-AC-3", "REQ-004-AC-4"]
    },
    {
      "type": "internal",
      "name": "resolveFlowMode",
      "input_schema": {
        "type": "object",
        "properties": {
          "detectedPath": {"type": "string", "enum": ["pure_greenfield", "first_time_onboarding", "returning_project"]},
          "userChoice": {"type": "string", "enum": ["greenfield", "feature"], "nullable": true, "description": "User's explicit choice. Null for pure_greenfield (auto-resolved)."}
        },
        "required": ["detectedPath"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "mode": {"type": "string", "enum": ["greenfield", "feature"]},
          "onboardingRequired": {"type": "boolean", "description": "True if first-time scan should run before proceeding"}
        }
      },
      "errors": [],
      "api_detail": null,
      "requirement_refs": ["REQ-004"],
      "acceptance_criteria_refs": ["REQ-004-AC-2", "REQ-004-AC-3", "REQ-004-AC-4", "REQ-004-AC-5"]
    },
    {
      "type": "internal",
      "name": "handleStalenessResponse",
      "input_schema": {
        "type": "object",
        "properties": {
          "rootDir": {"type": "string"},
          "stalenessResult": {"type": "object", "description": "Output from MOD-001 checkStaleness"},
          "userChoice": {"type": "string", "enum": ["regenerate", "proceed"]}
        },
        "required": ["rootDir", "stalenessResult", "userChoice"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "enum": ["regenerated", "acknowledged"]},
          "layersUpdated": {"type": "array", "items": {"type": "string"}, "description": "['l0', 'l1', 'l3'] if regenerated, [] if acknowledged"},
          "stalenessAcknowledged": {"type": "boolean", "description": "True if user chose to proceed despite staleness"}
        }
      },
      "errors": ["SCAN_FAILED", "WRITE_FAILED"],
      "api_detail": null,
      "requirement_refs": ["REQ-015"],
      "acceptance_criteria_refs": ["REQ-015-AC-1", "REQ-015-AC-2", "REQ-015-AC-3"]
    }
  ],
  "data_models": [
    {
      "name": "ModeContext",
      "fields": [
        {"name": "mode", "type": "'greenfield' | 'feature'", "constraints": "required, set once at flow start"},
        {"name": "detectedPath", "type": "'pure_greenfield' | 'first_time_onboarding' | 'returning_project'", "constraints": "diagnostic info"},
        {"name": "onboardingRequired", "type": "boolean", "constraints": "true triggers scan before mode selection"},
        {"name": "featureSlug", "type": "string | null", "constraints": "set when mode=feature, slugified from user description"},
        {"name": "stalenessAcknowledged", "type": "boolean", "constraints": "true if user chose to proceed despite stale profile, recorded as known_risk in feature discover artifact"}
      ],
      "relationships": []
    }
  ],
  "state_machine": {
    "states": ["detecting", "awaiting_user_choice", "onboarding", "resolved"],
    "transitions": [
      {"from": "detecting", "to": "resolved", "trigger": "no_code_no_profile", "description": "Auto-resolve to greenfield"},
      {"from": "detecting", "to": "onboarding", "trigger": "code_exists_no_profile", "description": "First-time: scan then ask"},
      {"from": "detecting", "to": "awaiting_user_choice", "trigger": "profile_exists", "description": "Ask user: greenfield or feature?"},
      {"from": "onboarding", "to": "awaiting_user_choice", "trigger": "scan_complete", "description": "Profile generated, now ask user"},
      {"from": "awaiting_user_choice", "to": "resolved", "trigger": "user_chose", "description": "Mode locked"}
    ]
  },
  "nfr_constraints": {
    "performance": "Detection should complete within 1 second (only checks file existence + git status).",
    "security": null,
    "other": null
  },
  "requirement_refs": ["REQ-004", "REQ-015"],
  "invariant_refs": ["INV-001"]
}
