{
  "id": "MOD-001",
  "name": "profile-storage",
  "responsibility": "Profile layer schema definitions, file I/O utilities (read/write/validate), staleness detection, and config management. This is the v4-compatible interface layer — all profile access goes through this module.",
  "source_root": "src/profile/",
  "owned_files": [
    "src/profile/storage.ts",
    "src/profile/config.ts",
    "src/profile/types.ts",
    "schemas/profile-l0.schema.json",
    "schemas/profile-l1.schema.json",
    "schemas/profile-l2.schema.json",
    "schemas/profile-l3.schema.json",
    "schemas/profile-config.schema.json"
  ],
  "interfaces": [
    {
      "type": "internal",
      "name": "readLayer",
      "input_schema": {
        "type": "object",
        "properties": {
          "rootDir": {"type": "string", "description": "Project root directory"},
          "layer": {"type": "string", "enum": ["l0", "l1", "l2", "l3"]}
        },
        "required": ["rootDir", "layer"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "data": {"type": "object", "nullable": true, "description": "Parsed layer JSON, or null if file does not exist"},
          "valid": {"type": "boolean", "description": "Whether data conforms to layer schema"},
          "errors": {"type": "array", "items": {"type": "string"}, "description": "Schema validation errors, empty if valid"}
        }
      },
      "errors": ["FILE_NOT_FOUND", "PARSE_ERROR", "SCHEMA_VALIDATION_FAILED"],
      "api_detail": null,
      "requirement_refs": ["REQ-001", "REQ-003"],
      "acceptance_criteria_refs": ["REQ-001-AC-1", "REQ-001-AC-5", "REQ-003-AC-1", "REQ-003-AC-3"]
    },
    {
      "type": "internal",
      "name": "writeLayer",
      "input_schema": {
        "type": "object",
        "properties": {
          "rootDir": {"type": "string"},
          "layer": {"type": "string", "enum": ["l0", "l1", "l2", "l3"]},
          "data": {"type": "object", "description": "Layer content to write (updated_at is auto-injected)"}
        },
        "required": ["rootDir", "layer", "data"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "path": {"type": "string", "description": "Absolute path to written file"}
        }
      },
      "errors": ["SCHEMA_VALIDATION_FAILED", "WRITE_ERROR", "L2_DISABLED"],
      "api_detail": null,
      "requirement_refs": ["REQ-001", "REQ-002"],
      "acceptance_criteria_refs": ["REQ-001-AC-1", "REQ-001-AC-5", "REQ-001-AC-6", "REQ-002-AC-3"]
    },
    {
      "type": "internal",
      "name": "profileExists",
      "input_schema": {
        "type": "object",
        "properties": {
          "rootDir": {"type": "string"}
        },
        "required": ["rootDir"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "exists": {"type": "boolean", "description": "True if at least l0-infra.json exists"},
          "layers": {
            "type": "object",
            "properties": {
              "l0": {"type": "boolean"},
              "l1": {"type": "boolean"},
              "l2": {"type": "boolean"},
              "l3": {"type": "boolean"}
            }
          }
        }
      },
      "errors": [],
      "api_detail": null,
      "requirement_refs": ["REQ-004"],
      "acceptance_criteria_refs": ["REQ-004-AC-1"]
    },
    {
      "type": "internal",
      "name": "checkStaleness",
      "input_schema": {
        "type": "object",
        "properties": {
          "rootDir": {"type": "string"}
        },
        "required": ["rootDir"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "stale": {"type": "boolean"},
          "profileUpdatedAt": {"type": "string", "format": "date-time", "nullable": true},
          "latestCommitAt": {"type": "string", "format": "date-time", "nullable": true},
          "hoursApart": {"type": "number"},
          "thresholdHours": {"type": "number"}
        }
      },
      "errors": ["NO_GIT_REPO", "NO_PROFILE"],
      "api_detail": null,
      "requirement_refs": ["REQ-015"],
      "acceptance_criteria_refs": ["REQ-015-AC-1"]
    },
    {
      "type": "internal",
      "name": "readConfig",
      "input_schema": {
        "type": "object",
        "properties": {
          "rootDir": {"type": "string"}
        },
        "required": ["rootDir"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "l2Enabled": {"type": "boolean", "default": true},
          "scanThresholdFiles": {"type": "integer", "default": 500},
          "stalenessThresholdHours": {"type": "integer", "default": 24}
        }
      },
      "errors": [],
      "api_detail": null,
      "requirement_refs": ["REQ-001", "REQ-006", "REQ-015"],
      "acceptance_criteria_refs": ["REQ-001-AC-2", "REQ-006-AC-2", "REQ-015-AC-1"]
    },
    {
      "type": "internal",
      "name": "ensureGitignore",
      "input_schema": {
        "type": "object",
        "properties": {
          "rootDir": {"type": "string"}
        },
        "required": ["rootDir"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "added": {"type": "boolean", "description": "True if .nopilot/ was added to .gitignore"}
        }
      },
      "errors": [],
      "api_detail": null,
      "requirement_refs": ["REQ-001"],
      "acceptance_criteria_refs": ["REQ-001-AC-3"]
    }
  ],
  "data_models": [
    {
      "name": "ProfileL0Infra",
      "fields": [
        {"name": "updated_at", "type": "string (ISO 8601)", "constraints": "required, auto-set on write"},
        {"name": "languages", "type": "string[]", "constraints": "detected from source files"},
        {"name": "frameworks", "type": "string[]", "constraints": "detected from dependencies"},
        {"name": "package_manager", "type": "string | null", "constraints": "npm | yarn | pnpm | bun | null"},
        {"name": "runtime", "type": "string | null", "constraints": "e.g. 'Node.js 20'"},
        {"name": "build_tools", "type": "string[]", "constraints": "e.g. ['tsc', 'vite']"},
        {"name": "ci", "type": "{ provider: string, config_path: string } | null", "constraints": "detected from CI config files"},
        {"name": "test_framework", "type": "string | null", "constraints": "e.g. 'vitest', 'jest'"}
      ],
      "relationships": []
    },
    {
      "name": "ProfileL1Arch",
      "fields": [
        {"name": "updated_at", "type": "string (ISO 8601)", "constraints": "required"},
        {"name": "directory_structure", "type": "Record<string, string>", "constraints": "top-level dirs with one-line descriptions"},
        {"name": "modules", "type": "{ name: string, path: string, responsibility: string }[]", "constraints": "detected or from spec"},
        {"name": "dependency_directions", "type": "{ from: string, to: string, type: string }[]", "constraints": "module-to-module dependency graph"},
        {"name": "communication_patterns", "type": "string[]", "constraints": "e.g. 'file-artifact', 'cli-subcommand', 'REST'"},
        {"name": "design_patterns", "type": "string[]", "constraints": "e.g. 'command-driven', 'event-sourcing'"}
      ],
      "relationships": []
    },
    {
      "name": "ProfileL2Decisions",
      "fields": [
        {"name": "updated_at", "type": "string (ISO 8601)", "constraints": "required"},
        {"name": "design_philosophy", "type": "{ principle: string, justification: string, source_artifact: string }[]", "constraints": "extracted from discover.json"},
        {"name": "architecture_decisions", "type": "{ decision: string, rationale: string, alternatives: string[], source_artifact: string }[]", "constraints": "extracted from decisions.json"},
        {"name": "constraints", "type": "{ constraint: string, source: 'user_stated' | 'ai_inferred', source_artifact: string }[]", "constraints": "extracted from discover.json constraints"}
      ],
      "relationships": []
    },
    {
      "name": "ProfileL3Status",
      "fields": [
        {"name": "updated_at", "type": "string (ISO 8601)", "constraints": "required"},
        {"name": "test_coverage", "type": "{ total_tests: number, framework: string }", "constraints": "from build_report or test run"},
        {"name": "domain_model", "type": "{ entities: Entity[], relationships: Relationship[] }", "constraints": "merged from all discover.json domain_models"},
        {"name": "tech_debt", "type": "string[]", "constraints": "known issues from build_report"},
        {"name": "change_hotspots", "type": "string[]", "constraints": "directories with most recent changes"},
        {"name": "recent_features", "type": "string[]", "constraints": "feature slugs from specs/features/"}
      ],
      "relationships": []
    },
    {
      "name": "ProfileConfig",
      "fields": [
        {"name": "l2_enabled", "type": "boolean", "constraints": "default: true"},
        {"name": "scan_threshold_files", "type": "integer", "constraints": "default: 500"},
        {"name": "staleness_threshold_hours", "type": "integer", "constraints": "default: 24"}
      ],
      "relationships": []
    }
  ],
  "state_machine": null,
  "nfr_constraints": {
    "performance": "readLayer must complete within 2 seconds (REQ-003-AC-3). Profile files are small JSON (<100KB typical), so this is trivially met by fs.readFile + JSON.parse.",
    "security": null,
    "other": "Forward-compatible: readLayer/writeLayer interface must remain stable for v4 dreaming feature (REQ-001-AC-4). Trigger timing is NOT part of this interface — only storage operations."
  },
  "requirement_refs": ["REQ-001", "REQ-003", "REQ-015"],
  "invariant_refs": ["INV-002", "INV-004"]
}
