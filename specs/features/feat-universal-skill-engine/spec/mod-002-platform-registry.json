{
  "id": "MOD-002",
  "name": "PlatformRegistry",
  "responsibility": "管理平台适配器注册表，提供 active 平台列表和每个平台的占位符映射、安装路径配置",
  "interfaces": [
    {
      "type": "internal",
      "name": "getActivePlatforms",
      "input_schema": {},
      "output_schema": {
        "platforms": "PlatformAdapter[] — 状态为 active 的平台列表"
      },
      "errors": [],
      "requirement_refs": ["REQ-002"],
      "acceptance_criteria_refs": ["REQ-002-AC-2", "REQ-002-AC-3"]
    },
    {
      "type": "internal",
      "name": "getPlatform",
      "input_schema": {
        "name": "string — 平台名"
      },
      "output_schema": {
        "platform": "PlatformAdapter | undefined"
      },
      "errors": [],
      "requirement_refs": ["REQ-002"],
      "acceptance_criteria_refs": ["REQ-002-AC-1"]
    },
    {
      "type": "internal",
      "name": "validateMappingCompleteness",
      "input_schema": {
        "platform": "PlatformAdapter — 目标平台配置",
        "requiredVariables": "string[] — 源文件中使用的所有变量名"
      },
      "output_schema": {
        "valid": "boolean",
        "missingKeys": "string[] — 平台映射中缺失的变量名"
      },
      "errors": [],
      "requirement_refs": ["REQ-002"],
      "acceptance_criteria_refs": ["REQ-002-AC-4"]
    }
  ],
  "data_models": [
    {
      "name": "PlatformAdapter",
      "fields": [
        { "name": "name", "type": "string", "constraints": "平台标识符: claude | codex | gemini | opencode" },
        { "name": "status", "type": "'active' | 'experimental'", "constraints": "active 平台参与 init 安装，experimental 仅预留" },
        { "name": "skillsDir", "type": "string", "constraints": "目标安装目录（绝对路径，如 ~/.claude/skills/）" },
        { "name": "legacyDir", "type": "string | null", "constraints": "旧版安装目录（需要迁移清理的路径），无旧版则为 null" },
        { "name": "placeholderMap", "type": "Record<string, string>", "constraints": "占位符变量名 → 该平台的实际值映射" }
      ],
      "relationships": [
        { "target": "TemplateEngine.RenderContext", "type": "has_one" }
      ]
    }
  ],
  "state_machine": null,
  "nfr_constraints": {
    "performance": null,
    "security": null,
    "other": null
  },
  "requirement_refs": ["REQ-002"],
  "invariant_refs": ["INV-001"]
}
