{
  "name": "nopilot",
  "version": "4.0",
  "max_backtrack_count": 3,
  "backtrack_cycle_detection": true,

  "framework_principles": {
    "generation_review_separation": {
      "description": "Generating agents must NEVER evaluate their own output. All review/assessment is performed by independent agents in isolated sessions.",
      "applies_to": "all_stages",
      "enforcement": "mandatory"
    },
    "iterative_verification": {
      "description": "Review cycles use fresh agent instances each round to avoid anchoring bias. Limits float by complexity.",
      "max_iterations": {
        "simple": 3,
        "moderate": 5,
        "complex": 10
      },
      "on_limit_reached": {
        "converging": "extend_iterations",
        "diverging": "escalate_model",
        "oscillating": "escalate_human"
      }
    },
    "agent_consensus": {
      "description": "Before asking the human, the executing agent spawns a consulting agent anchored on design philosophy and first principles. If they disagree, one more round of discussion attempts convergence.",
      "consulting_agent_anchors": ["design_philosophy", "first_principles"],
      "decision_tiers": {
        "low_impact": { "scope": "technical implementation details", "auto_approve": true, "log_to": "decisions.json" },
        "medium_impact": { "scope": "architecture decisions not affecting product direction", "notify_human": true, "auto_approve_if_no_objection": true },
        "high_impact": { "scope": "product direction, user-visible behavior", "require_human_confirmation": true }
      },
      "max_consensus_rounds": 2,
      "on_no_convergence": "present_both_viewpoints_to_human"
    }
  },

  "agents": {
    "supervisor": {
      "trigger": "stage_complete",
      "input": ["discover.json#constraints", "discover.json#selected_direction", "discover.json#tech_direction", "discover.json#design_philosophy", "decisions.json", "current_stage_output"],
      "output_field": "global_coherence_check",
      "classification": "core_guardrail",
      "on_drift": "pause_notify_user"
    },
    "critic": {
      "trigger": "checkpoint_review",
      "input": ["relevant_contract_artifacts_only"],
      "output_field": "independent_review",
      "session": "independent",
      "classification": "core_guardrail",
      "on_issue": "self_fix_then_reverify_with_fresh_instance",
      "iteration_limits": "dynamic_by_complexity",
      "6cs_grading": {
        "mandatory_block": ["completeness", "consistency", "correctness"],
        "advisory_warn": ["clarity", "conciseness", "concreteness"]
      }
    }
  },

  "enhancement_guardrails": {
    "tracer_bullet": { "enabled": true, "phase": "build" },
    "mutation_testing": { "enabled": false, "phase": "build" },
    "multi_sample_6cs": { "enabled": false, "phase": "discover" }
  },

  "artifact_structure": {
    "description": "Large artifacts split into directory structure with index file. Small artifacts remain as single files.",
    "split_threshold": "when_artifact_exceeds_reasonable_single_file_size_or_contains_multiple_modules",
    "discover": {
      "single_file": "specs/discover.json",
      "directory": {
        "path": "specs/discover/",
        "index": "index.json",
        "children": ["requirements.json", "scenarios.json", "history.json"]
      }
    },
    "spec": {
      "single_file": "specs/spec.json",
      "directory": {
        "path": "specs/spec/",
        "index": "index.json",
        "children_pattern": "mod-{id}-{name}.json"
      }
    },
    "build": {
      "single_file": "specs/build_report.json",
      "directory": {
        "path": "specs/build/",
        "index": "index.json",
        "children_pattern": "mod-{id}-{name}.json"
      }
    },
    "tests": {
      "single_file": "specs/tests.json",
      "directory": {
        "path": "specs/tests/",
        "index": "index.json",
        "children_pattern": "mod-{id}-{name}.json"
      }
    }
  },

  "stages": {
    "discover": {
      "command": "/discover",
      "description": "Requirement space exploration and convergence",
      "context_dependencies": [],
      "backtrack_context": ["specs/discover_history.json"],
      "outputs": ["specs/discover.json", "specs/discover_history.json", "specs/discover_review.json"],
      "checkpoint": "required",
      "states": {
        "initial": "idea_collection",
        "idea_collection": {
          "on": {
            "IDEA_CAPTURED": "idea_structuring"
          }
        },
        "idea_structuring": {
          "on": {
            "IDEA_CONFIRMED": "constraint_collection"
          }
        },
        "constraint_collection": {
          "on": {
            "MODE_SELECTED": "direction"
          }
        },
        "direction": {
          "on": {
            "SELECT": "mvp",
            "MERGE": "mvp",
            "REJECT_ALL": "direction"
          }
        },
        "mvp": {
          "on": {
            "APPROVE": "design_philosophy",
            "BACKTRACK": "direction"
          }
        },
        "design_philosophy": {
          "on": {
            "PHILOSOPHY_CONFIRMED": "lock"
          }
        },
        "lock": {
          "on": {
            "APPROVE": "$complete",
            "REVISE": "lock",
            "FORCE_OVERRIDE": "$complete",
            "BACKTRACK_MVP": "mvp",
            "BACKTRACK_DIR": "direction"
          },
          "guards": {
            "APPROVE": {
              "critic_review_passed": true,
              "no_unresolved_conflicts": true,
              "invariants_extracted": true,
              "completeness_threshold_met": true
            },
            "FORCE_OVERRIDE": {
              "note": "User acknowledges unresolved issues and proceeds anyway"
            }
          }
        }
      },
      "allowed_actions": {
        "direction": [
          { "type": "SELECT", "params": { "index": "number" } },
          { "type": "MERGE", "params": { "indices": "number[]", "note": "string" } },
          { "type": "REJECT_ALL", "params": { "reason": "string" } }
        ],
        "mvp": [
          { "type": "APPROVE" },
          { "type": "BACKTRACK" }
        ],
        "lock": [
          { "type": "APPROVE" },
          { "type": "REVISE", "params": { "requirement_ids": "string[]", "changes": "string" } },
          { "type": "FORCE_OVERRIDE", "params": { "acknowledged_issues": "string[]" } },
          { "type": "BACKTRACK_MVP" },
          { "type": "BACKTRACK_DIR" }
        ]
      }
    },
    "spec": {
      "command": "/spec",
      "description": "Constrained design expansion to module-level specifications",
      "context_dependencies": ["specs/discover.json"],
      "backtrack_context": ["specs/build_report.json"],
      "outputs": ["specs/spec.json", "specs/spec_review.json"],
      "checkpoint": "conditional",
      "checkpoint_trigger": "review_issues_found OR high_impact_auto_decisions_exist OR information_gap_with_options",
      "states": {
        "initial": "expanding",
        "expanding": {
          "on": {
            "COMPLETE": "reviewing",
            "CONTRADICTION": "$backtrack:discover",
            "GAP_HIGH_IMPACT": "awaiting_user",
            "L0_ISSUE": "expanding"
          }
        },
        "awaiting_user": {
          "on": {
            "USER_DECISION": "expanding"
          },
          "allowed_actions": [
            { "type": "USER_DECISION", "params": { "choice": "string" } }
          ]
        },
        "reviewing": {
          "on": {
            "REVIEW_CLEAN": "$complete",
            "REVIEW_HAS_ISSUES": "awaiting_review",
            "REVIEW_FIXABLE": "expanding"
          }
        },
        "awaiting_review": {
          "on": {
            "APPROVED": "$complete",
            "CHANGES_REQUESTED": "expanding"
          },
          "allowed_actions": [
            { "type": "APPROVED" },
            { "type": "CHANGES_REQUESTED", "params": { "changes": "string" } }
          ]
        }
      }
    },
    "build": {
      "command": "/build",
      "description": "TDD implementation per spec with tracer bullet and auto-acceptance",
      "context_dependencies": ["specs/spec.json", "specs/discover.json"],
      "backtrack_context": [],
      "outputs": ["specs/tests.json", "specs/build_report.json", "specs/build_review.json"],
      "test_review_checkpoint": "required",
      "max_retries_per_module": 3,
      "states": {
        "initial": "planning",
        "planning": {
          "on": {
            "PLAN_READY": "testing",
            "L3_ISSUE": "diagnosing"
          }
        },
        "testing": {
          "on": {
            "TESTS_GENERATED": "test_reviewing",
            "L3_ISSUE": "diagnosing"
          }
        },
        "test_reviewing": {
          "on": {
            "TEST_REVIEW_PASSED": "tracer_bullet",
            "TEST_REVIEW_FAILED": "testing"
          }
        },
        "tracer_bullet": {
          "on": {
            "TRACER_PASS": "implementing",
            "TRACER_L0L1_FAIL": "tracer_bullet",
            "TRACER_L2L3_FAIL": "diagnosing",
            "SKIP": "implementing"
          },
          "guards": {
            "SKIP": { "guardrails.enhancement.tracer_bullet.enabled": false }
          }
        },
        "implementing": {
          "on": {
            "ALL_MODULES_DONE": "verifying",
            "L0_ISSUE": "env_waiting",
            "L1_RESOLVED": "implementing",
            "L2_ISSUE": "awaiting_user",
            "L3_ISSUE": "diagnosing"
          }
        },
        "env_waiting": {
          "on": {
            "ENV_RESOLVED": "implementing",
            "ENV_EXHAUSTED_WITH_ALT": "awaiting_user",
            "ENV_EXHAUSTED_NO_ALT": "diagnosing"
          }
        },
        "awaiting_user": {
          "on": {
            "ACCEPT_DEGRADATION": "amending",
            "CUT_FEATURE": "replanning",
            "MODIFY_SPEC": "$backtrack:spec",
            "RETRY_DIFFERENT_APPROACH": "implementing",
            "BACKTRACK_DISCOVER": "$backtrack:discover"
          },
          "allowed_actions": [
            { "type": "ACCEPT_DEGRADATION", "params": { "detail": "string" } },
            { "type": "CUT_FEATURE", "params": { "feature": "string" } },
            { "type": "MODIFY_SPEC" },
            { "type": "RETRY_DIFFERENT_APPROACH", "params": { "hint": "string?" } },
            { "type": "BACKTRACK_DISCOVER" }
          ]
        },
        "amending": {
          "on": {
            "AMENDMENT_RECORDED": "implementing"
          }
        },
        "replanning": {
          "on": {
            "REPLAN_READY": "implementing",
            "REPLAN_INCOMPLETE": "diagnosing"
          }
        },
        "diagnosing": {
          "on": {
            "BACKTRACK_SPEC": "$backtrack:spec",
            "BACKTRACK_DISCOVER": "$backtrack:discover"
          },
          "allowed_actions": [
            { "type": "BACKTRACK_SPEC" },
            { "type": "BACKTRACK_DISCOVER" }
          ]
        },
        "verifying": {
          "on": {
            "ALL_PASS": "accepting",
            "FAILURES": "implementing"
          }
        },
        "accepting": {
          "on": {
            "ACCEPTANCE_PASS": "$complete",
            "ACCEPTANCE_FAIL_L2": "awaiting_user",
            "ACCEPTANCE_FAIL_L3": "diagnosing"
          }
        }
      }
    }
  },

  "backtrack_triggers": [
    { "from": "spec", "to": "discover", "condition": "contradiction_in_discover_json" },
    { "from": "build", "to": "spec", "condition": "spec_interface_infeasible" },
    { "from": "build", "to": "discover", "condition": "requirement_level_fundamental_issue" }
  ],
  "backtrack_strategy": "full_rerun"
}
